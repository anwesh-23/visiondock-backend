  "cells": [
    {
      "cell_type": "code",
      "source": [
        "# Install ultralytics if not already installed\n",
        "!pip install ultralytics\n",
        "# Install pyttsx3 if not already installed\n",
        "!pip install pyttsx3\n",
        "# Install espeak-ng for pyttsx3\n",
        "!apt-get install espeak-ng\n",
        "\n",
        "import cv2\n",
        "import pyttsx3\n",
        "from ultralytics import YOLO\n",
        "import numpy as np\n",
        "\n",
        "# Load YOLO model\n",
        "model = YOLO(\"yolov8n.pt\")\n",
        "\n",
        "# Voice engine\n",
        "engine = pyttsx3.init()\n",
        "\n",
        "def speak(text):\n",
        "    engine.say(text)\n",
        "    engine.runAndWait()\n",
        "\n",
        "last_spoken = \"\"\n",
        "\n",
        "# Function to check if image is blurry\n",
        "def is_blurry(frame):\n",
        "    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n",
        "    variance = cv2.Laplacian(gray, cv2.CV_64F).var()\n",
        "    return variance < 100  # lower = blurry\n",
        "\n",
        "# Start camera\n",
        "cap = cv2.VideoCapture(0)\n",
        "\n",
        "while True:\n",
        "    ret, frame = cap.read()\n",
        "    if not ret:\n",
        "        break\n",
        "\n",
        "    frame_center_x = frame.shape[1] // 2\n",
        "\n",
        "    # 🔍 Check if camera is blurry\n",
        "    if is_blurry(frame):\n",
        "        alert = \"Camera not clear, please clean your camera\"\n",
        "        cv2.putText(frame, alert, (30, 50),\n",
        "                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0,0,255), 2)\n",
        "\n",
        "        if last_spoken != alert:\n",
        "            speak(alert)\n",
        "            last_spoken = alert\n",
        "\n",
        "    else:\n",
        "        # Run YOLO\n",
        "        results = model(frame)\n",
        "\n",
        "        for r in results:\n",
        "            for box in r.boxes:\n",
        "                x1, y1, x2, y2 = map(int, box.xyxy[0])\n",
        "                cls = int(box.cls[0])\n",
        "                label = model.names[cls]\n",
        "\n",
        "                # Draw box\n",
        "                cv2.rectangle(frame, (x1, y1), (x2, y2), (0,255,0), 2)\n",
        "                cv2.putText(frame, label, (x1, y1-10),\n",
        "                            cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0,255,0), 2)\n",
        "\n",
        "                # Object position\n",
        "                obj_center_x = (x1 + x2) // 2\n",
        "\n",
        "                # 🎯 LEFT / RIGHT / CENTER LOGIC\n",
        "                if abs(obj_center_x - frame_center_x) < 100:\n",
        "                    alert = \"Stop, obstacle ahead\"\n",
        "                    color = (0,0,255)\n",
        "\n",
        "                elif obj_center_x < frame_center_x:\n",
        "                    alert = \"Obstacle on left, move right\"\n",
        "                    color = (0,255,255)\n",
        "\n",
        "                else:\n",
        "                    alert = \"Obstacle on right, move left\"\n",
        "                    color = (255,0,0)\n",
        "\n",
        "                # Show alert\n",
        "                cv2.putText(frame, alert, (30, 50),\n",
        "                            cv2.FONT_HERSHEY_SIMPLEX, 0.8, color, 2)\n",
        "\n",
        "                # Speak only if changed\n",
        "                if last_spoken != alert:\n",
        "                    speak(alert)\n",
        "                    last_spoken = alert\n",
        "\n",
        "    # Show frame\n",
        "    cv2.imshow(\"VisionDock Prototype\", frame)\n",
        "\n",
        "    if cv2.waitKey(1) & 0xFF == ord('q'):\n",
        "        break\n",
        "\n",
        "cap.release()\n",
        "cv2.destroyAllWindows()"
      ],
      "metadata": {
